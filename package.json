{
  "name": "root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22 || 24"
  },
  "scripts": {
    "prestart": "test -f .env || cp .env.example .env",
    "start": "docker compose -f docker-compose.local.yaml up -d --wait && dotenv -e .env -- backstage-cli repo start",
    "start:app": "dotenv -e .env -- backstage-cli repo start",
    "stop:local": "docker compose -f docker-compose.local.yaml down",
    "db:status": "docker compose -f docker-compose.local.yaml ps && docker compose -f docker-compose.local.yaml exec postgres psql -U postgres -c \"SELECT datname FROM pg_database WHERE datname LIKE 'backstage_plugin_%' ORDER BY datname;\" && docker compose -f docker-compose.local.yaml exec postgres psql -U postgres -c \"SELECT datname, count(*) AS connections FROM pg_stat_activity WHERE datname LIKE 'backstage_plugin_%' GROUP BY datname ORDER BY datname;\" && docker compose -f docker-compose.local.yaml exec postgres psql -U postgres -d backstage_plugin_catalog -c \"SELECT name FROM knex_migrations ORDER BY id DESC LIMIT 5;\"",
    "build:backend": "yarn workspace backend build",
    "build:all": "backstage-cli repo build --all",
    "build-image": "yarn workspace backend build-image",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false",
    "clean": "backstage-cli repo clean",
    "test": "backstage-cli repo test",
    "test:all": "backstage-cli repo test --coverage",
    "test:e2e": "playwright test",
    "fix": "backstage-cli repo fix",
    "lint": "backstage-cli repo lint --since origin/main",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "prepare": "husky",
    "new": "backstage-cli new"
  },
  "backstage": {
    "cli": {
      "new": {
        "globals": {
          "license": "UNLICENSED"
        }
      }
    }
  },
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/cli-defaults": "^0.1.3",
    "@backstage/e2e-test-utils": "^0.1.2",
    "@jest/environment-jsdom-abstract": "~30.2.0",
    "@playwright/test": "^1.32.3",
    "@types/jest": "^30.0.0",
    "dotenv-cli": "^8.0.0",
    "husky": "^9.1.7",
    "jest": "~30.2.0",
    "jsdom": "^27.1.0",
    "lint-staged": "^17.0.8",
    "node-gyp": "^10.0.0",
    "prettier": "^2.3.2",
    "typescript": "~5.8.0"
  },
  "resolutions": {
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "prettier": "@backstage/cli/config/prettier",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.13.0"
}
