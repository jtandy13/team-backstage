{
  "name": "@internal/plugin-deployment-info",
  "version": "0.1.0",
  "private": true,
  "description": "Backstage plugin that shows live deployment details on service entity pages",
  "backstage": {
    "role": "frontend-plugin",
    "pluginId": "deployment-info",
    "pluginPackages": [
      "@internal/plugin-deployment-info"
    ],
    "features": {
      "./alpha": "@backstage/FrontendPlugin"
    }
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./alpha": "./src/alpha.ts",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "alpha": [
        "src/alpha.ts"
      ],
      "package.json": [
        "package.json"
      ]
    }
  },
  "scripts": {
    "start": "backstage-cli package start",
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "test": "backstage-cli package test",
    "lint": "backstage-cli package lint"
  },
  "dependencies": {
    "@backstage/catalog-model": "^1.9.0",
    "@backstage/core-components": "^0.18.11",
    "@backstage/core-plugin-api": "^1.12.7",
    "@backstage/frontend-plugin-api": "^0.17.2",
    "@backstage/plugin-catalog-react": "^3.1.0",
    "@material-ui/core": "^4.12.2",
    "react": "^18.0.2",
    "react-dom": "^18.0.2",
    "react-router-dom": "^6.30.2",
    "react-use": "^17.2.4"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "@backstage/frontend-test-utils": "^0.6.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.0.0",
    "jest": "~30.2.0"
  },
  "files": [
    "dist"
  ]
}
